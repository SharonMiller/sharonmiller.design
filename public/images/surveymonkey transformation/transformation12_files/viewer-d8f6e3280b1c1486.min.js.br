`,sr=`
  type ColorValue = {
    r: number,
    g: number,
    b: number,
    a: number,
  }

  export type ImageValue = {
    src: string,
    alt?: string,
    height?: number,
    width?: number,
  }

  export type StringSetterPropKeys<Props> = keyof Props
  export type StringPropertySpec<Props> = {
    type: 'string',
    label?: string,
    defaultValue?: string,
    setter?: StringSetterPropKeys<Props>,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type StringPropertySelectSpec<Props> = StringPropertySpec<Props> & {
    control: 'select',
    options: {
      value: string,
      label: string,
    }[],
  }

  export type BooleanSetterPropKeys<Props> = keyof Props
  export type BooleanPropertySpec<Props> = {
    type: 'boolean',
    label?: string,
    defaultValue?: boolean,
    setter?: BooleanSetterPropKeys<Props>,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type NumberSetterPropKeys<Props> = keyof Props
  export type NumberPropertySpec<Props> = {
    type: 'number',
    label?: string,
    defaultValue?: number,
    setter?: NumberSetterPropKeys<Props>,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type NumberPropertySliderSpec<Props> = NumberPropertySpec<Props> & {
    control: 'slider',
    min: number,
    max: number,
    step: number,
    unit?: string,
  }

  export type NumberPropertyInputSpec<Props> = NumberPropertySpec<Props> & {
    control: 'input',
    unit?: string,
    min?: number,
    max?: number,
  }

  export type NumberPropertySelectSpec<Props> = NumberPropertySpec<Props> & {
    control: 'select',
    options: {
      value: number,
      label: string,
    }[],
  }

  export type StringOrNumberPropertySelectSpec<Spec, T extends string | number> = Spec & {
    control: 'select',
    options: {
      value: T,
      label: string,
    }[],
  }

  export type ColorSetterPropKeys<Props> = keyof Props
  export type ColorPropertySpec<Props> = {
    type: 'color',
    label?: string,
    defaultValue?: ColorValue,
    setter?: ColorSetterPropKeys<Props>,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type ComponentReferencePropKeys<Props> = keyof Props
  export type ComponentReferencePropertySpec<Props> = {
    type: 'reference',
    label?: string,
    defaultValue?: React.FunctionComponent<any>,
    setter?: ComponentReferencePropKeys<Props>,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type ImagePropertySpec<Props> = {
    type: 'image',
    label?: string,
    defaultValue?: string | ImageValue,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type EasingTypeString =
    | 'inCubic'
    | 'outCubic'
    | 'inOutCubic'
    | 'linear'
    | 'inBackCubic'
    | 'outBackCubic'
    | 'inOutBackCubic'
    | 'customCubic'
    | 'spring'
    | 'gentleSpring'
    | 'customSpring'
    | 'springPresetOne'
    | 'springPresetTwo'
    | 'springPresetThree'
    | 'bezier'

  export enum EasingType {
    IN_CUBIC = 0,
    OUT_CUBIC = 1,
    INOUT_CUBIC = 2,
    LINEAR = 3,
    IN_BACK_CUBIC = 4,
    OUT_BACK_CUBIC = 5,
    INOUT_BACK_CUBIC = 6,
    CUSTOM_CUBIC = 7,
    SPRING = 8,
    GENTLE_SPRING = 9,
    CUSTOM_SPRING = 10,
    SPRING_PRESET_ONE = 11,
    SPRING_PRESET_TWO = 12,
    SPRING_PRESET_THREE = 13,

    // For backwards compat
    BEZIER = 100,
  }

  export type SpringValue = {
    mass: number,
    stiffness: number,
    damping: number,
  }

  export type BezierValue = {
    p1x: number,
    p1y: number,
    p2x: number,
    p2y: number,
  }

  export type EasingData = {
    easingType: EasingType | EasingTypeString,
    springValues?: SpringValue,
    bezierValues?: BezierValue,
  }

  export type EasingPropertySpec<Props> = {
    type: 'easing',
    label?: string,
    defaultValue?: EasingData,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type PointValue = {
    x: number,
    y: number,
  }

  export type PointSetterPropKeys<Props> = keyof Props
  export type PointPropertySpec<Props> = {
    type: 'point',
    label?: string,
    defaultValue: PointValue,
    mode?: 'canvas' | 'ui' | 'canvas_and_ui',
    unit?: string,
    setter?: PointSetterPropKeys<Props>,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type PointRadiusValue = {
    x: number,
    y: number,
    radius: number,
  }

  export type PointRadiusSetterPropKeys<Props> = keyof Props
  export type PointRadiusPropertySpec<Props> = {
    type: 'point-radius',
    label?: string,
    defaultValue: PointRadiusValue,
    mode?: 'canvas' | 'ui' | 'canvas_and_ui',
    positionUnit?: string,
    radiusUnit?: string,
    minRadius?: number,
    maxRadius?: number,
    setter?: PointRadiusSetterPropKeys<Props>,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type ColorPointValue = {
    x: number,
    y: number,
    color: ColorValue,
  }

  export type ColorPointSetterPropKeys<Props> = keyof Props
  export type ColorPointPropertySpec<Props> = {
    type: 'color-point',
    label?: string,
    defaultValue: ColorPointValue,
    mode?: 'canvas' | 'ui' | 'canvas_and_ui',
    unit?: string,
    setter?: ColorPointSetterPropKeys<Props>,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type GradientStopValue = {
    position: number,
    color: ColorValue,
  }

  export type GradientValue = {
    stops: GradientStopValue[],
  }

  export type GradientPropertySpec<Props> = {
    type: 'gradient',
    label?: string,
    defaultValue?: GradientValue,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type PointPointLineValue = {
    x: number,
    y: number,
    x2: number,
    y2: number,
  }

  export type PointPointLineSetterPropKeys<Props> = keyof Props
  export type PointPointLinePropertySpec<Props> = {
    type: 'point-point-line',
    label?: string,
    defaultValue: PointPointLineValue,
    mode?: 'canvas' | 'ui' | 'canvas_and_ui',
    unit?: string,
    setter?: PointPointLineSetterPropKeys<Props>,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type PointAngleRadiusValue = {
    x: number,
    y: number,
    radius: number,
    // angle in degrees.
    angle: number,
  }

  export type PointAngleRadiusSetterPropKeys<Props> = keyof Props
  export type PointAngleRadiusPropertySpec<Props> = {
    type: 'point-angle-radius',
    label?: string,
    defaultValue: PointAngleRadiusValue,
    mode?: 'canvas' | 'ui' | 'canvas_and_ui',
    positionUnit?: string,
    radiusUnit?: string,
    minRadius?: number,
    maxRadius?: number,
    setter?: PointAngleRadiusSetterPropKeys<Props>,
    sortPosition?: number,
    showDividerAbove?: boolean,
  }

  export type PropertySpec<Props> =
    | StringPropertySpec<Props>
    | StringPropertySelectSpec<Props>
    | BooleanPropertySpec<Props>
    | NumberPropertySpec<Props>
    | NumberPropertySliderSpec<Props>
    | NumberPropertyInputSpec<Props>
    | NumberPropertySelectSpec<Props>
    | ColorPropertySpec<Props>
    | ComponentReferencePropertySpec<Props>
    | ImagePropertySpec<Props>
    | EasingPropertySpec<Props>
    | PointPropertySpec<Props>
    | PointRadiusPropertySpec<Props>
    | ColorPointPropertySpec<Props>
    | PointPointLinePropertySpec<Props>
    | PointAngleRadiusPropertySpec<Props>
    | GradientPropertySpec<Props>

  type InferPropertySpec<T, Props> =
    T extends string ? StringPropertySpec<Props> | StringPropertySelectSpec<Props> :
    T extends number
      ? NumberPropertySpec<Props> | NumberPropertySliderSpec<Props> | NumberPropertyInputSpec<Props> | NumberPropertySelectSpec<Props> :
    T extends boolean ? BooleanPropertySpec<Props> :
    T extends ColorValue ? ColorPropertySpec<Props> :
    // PointAngleRadiusValue ({x, y, radius, angle}) is structurally assignable to
    // PointRadiusValue ({x, y, radius}) and PointValue ({x, y}); test the most-
    // specific shape first so it doesn't get short-circuited by either.
    T extends PointAngleRadiusValue ? PointAngleRadiusPropertySpec<Props> :
    // PointPointLineValue ({x, y, x2, y2}) is structurally assignable to
    // PointValue ({x, y}); test the more-specific shape first so it doesn't
    // get short-circuited by PointValue.
    T extends PointPointLineValue ? PointPointLinePropertySpec<Props> :
    T extends PointRadiusValue ? PointRadiusPropertySpec<Props> :
    T extends ColorPointValue ? ColorPointPropertySpec<Props> :
    T extends PointValue ? PointPropertySpec<Props> :
    T extends FunctionComponent<any> ? ComponentReferencePropertySpec<Props> :
    T extends ImageValue ? ImagePropertySpec<Props> :
    T extends EasingData ? EasingPropertySpec<Props> :
    T extends GradientValue ? GradientPropertySpec<Props> :
    PropertySpec<Props>

  export type PropertiesSpec<Props> = Partial<{
    [K in keyof Props]: InferPropertySpec<Props[K], Props>
  }>
