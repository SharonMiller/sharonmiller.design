# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# Vercel deployment URLs — used to link between environments in the app.
# Leave blank for local dev. Set in each Vercel project's Environment Variables.
VITE_VERCEL_URL=

# Site password for Vercel Edge Middleware (middleware.ts + /api/auth).
# Leave unset for local `npm run dev` (protection disabled). Set in Vercel only.
SITE_PASSWORD=
